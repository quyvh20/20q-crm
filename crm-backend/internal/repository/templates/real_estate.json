  "automation_rules": [
    {
      "key": "new_enquiry_callback",
      "name": "Call back a new enquiry within a day",
      "description": "Property enquiries go cold fast — this books the callback the moment a contact is created.",
      "activation": "auto",
      "trigger": {
        "type": "contact_created"
      },
      "steps": [
        {
          "type": "action",
          "id": "s1",
          "action": {
            "id": "s1",
            "type": "create_task",
            "params": {
              "title": "Call {{contact.first_name}} about their property search",
              "priority": "high",
              "due_in_days": 1
            }
          }
        }
      ]
    },
    {
      "key": "won_handover",
      "name": "Hand over on completion",
      "description": "Fires the moment a deal reaches Notarized — the point where work is won and something has to happen next.",
      "activation": "auto",
      "trigger": {
        "type": "deal_stage_changed",
        "params": {
          "to_stage": "Notarized"
        }
      },
      "steps": [
        {
          "type": "action",
          "id": "s1",
          "action": {
            "id": "s1",
            "type": "create_task",
            "params": {
              "title": "Hand the keys to {{contact.first_name}}, confirm the file is closed and ask for a referral",
              "priority": "high",
              "due_in_days": 3
            }
          }
        }
      ]
    }
  ],
  "kb_templates": {
    "company": "## About us\n\nWe are a real estate agency serving [your area]. Replace this with who you are, the neighbourhoods you cover, and how long you have been trading.\n\n## Contact\n\nOffice address, phone, and opening hours.",
    "products": "## What we handle\n\n- Residential sales\n- Rentals and property management\n- Commercial property\n\nList your typical price bands and the areas you know best.",
    "playbook": "## Qualifying a buyer\n\n1. Budget, and whether financing is already arranged.\n2. Must-have area, size and number of bedrooms.\n3. Timeline — when do they need to move?\n4. Whether they have a property to sell first.\n\n## Viewing follow-up\n\nCall within 24 hours of every viewing. Ask what they liked, what they did not, and offer two alternatives.",
    "process": "## From enquiry to keys\n\n1. **New Enquiry** — log the contact and what they are looking for.\n2. **Qualified** — budget and financing confirmed.\n3. **Viewing Scheduled** — at least two properties booked.\n4. **Offer Made** — offer submitted to the seller.\n5. **Deposit Paid** — deposit received, property reserved.\n6. **Notarized** — contract signed at the notary.",
    "competitors": "## Why clients choose us\n\nReplace with your genuine differentiators — local knowledge, exclusive listings, speed of response, negotiated fees."
  }
}
