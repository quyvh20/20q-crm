# --- App Config ---
PORT=8080

# --- Database ---
# Local Docker: postgres://crm_user:crm_password@localhost:5432/crm_db?sslmode=disable
# Supabase: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DATABASE_URL=

# --- Redis ---
# Local Docker: redis://localhost:6379
REDIS_URL=

# --- Auth ---
JWT_SECRET=dev-secret-change-me-in-production-32chars!

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/auth/google/callback

# --- Frontend ---
FRONTEND_URL=http://localhost:5173

# --- Monitoring ---
SENTRY_DSN=

# --- AI (Cloudflare) ---
CF_ACCOUNT_ID=
CF_AI_TOKEN=

# --- Payments (Paddle) ---
PADDLE_WEBHOOK_SECRET=

# --- Email (Resend) ---
RESEND_API_KEY=
